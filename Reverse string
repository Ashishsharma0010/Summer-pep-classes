Q : REVERSE STRING 
#include<bits/stdc++.h>
using namespace std;
void reverse_string(vector<char>&arr){
    int n=arr.size();
    int start=0;
    int end=n-1;
    while(start<=end){
        swap(arr[start],arr[end]);
        start++;
        end--;
    }
}
int main(){
    int n;
    cin>>n;
     vector<char> arr(n);
    for(int i=0;i<n; i++){
        cin>>arr[i];
    }
    reverse_string(arr);
    for(int i=0; i<n; i++){
        cout<<arr[i]<<" ";
    }
}
Tine complexity O(N);
