Q : BINARY SEARCH        BUT IN THIS ARRAY MUST BE SORTED
#include<bits/stdc++.h>
using namespace std;
int binary_search(int arr[],int n,int target){
    
    int low=0;
    int high=n-1;
    int mid=low+(high-low)/2;
    while(low<=high){
        mid=low+(high-low)/2;
        if(arr[mid]==target){
            return mid;
        }
        if(arr[mid]>target){
            high=mid-1;
        }
        else{
            low=mid+1;
        }
    }
    return -1;
}
int main(){
int n;
cin>>n;
int arr[n];
for(int i=0; i<n; i++){
    cin>>arr[i];
}
int target;
cin>>target;
sort(arr,arr+n);
int ans=binary_search(arr, n,target);
cout<<ans;
}
time complexity of this O(LOG N)
Space complexity of this code is O(1);
