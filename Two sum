Q: Two sum
#include<bits/stdc++.h>
using namespace std;
vector<int> two_sum(vector<int>&nums, int target){
    int n=nums.size();
    for(int i=0; i<n; i++){
        for(int j=i+1; j<n; j++){
            if(nums[i]+nums[j]==target){
                return {i,j};
            }
        }
    }
    return {-1,-1};
}
int main(){
    int n;
    cin>>n;
    vector<int> nums(n);
    for(int i=0; i<n; i++){
        cin>>nums[i];
    }
    int target;
    cin>>target;
    vector<int> result=two_sum(nums,target);
    
    for(int i=0; i<result.size(); i++){
        cout<<result[i]<<" ";
    }
}
Time complexity is O(N*2) Because roop is running two time thats why
Space complexity of this code is We are not using any extra data structure whose size depends on n. O(1)
